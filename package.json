{
  "name": "riveto-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint": "npm run --prefix frontend lint && npm run --prefix backend lint && npm run --prefix admin lint",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0"
  },
  "lint-staged": {
    "**/*.{js,jsx,json,md}": [
      "prettier --write"
    ],
    "frontend/**/*.{js,jsx}": [
      "npm --prefix frontend run lint:fix --"
    ],
    "backend/**/*.js": [
      "npm --prefix backend run lint:fix --"
    ]
  }
}
